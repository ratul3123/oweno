# Enforce LF line endings for text files
*.js     text eol=lf
*.jsx    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.css    text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.html   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.txt    text eol=lf
*.sh     text eol=lf

# Binary files - no end-of-line conversions
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary

# Other configuration files
*.lock   text eol=lf
.DS_Store binary

# Normalize everything else automatically
* text=auto
